/datafield><datafield tag="412" ind1="b" ind2="1"><subfield code="a">The Hockey Association (Verkauf)</subfield></datafield><datafield tag="425" ind1="a" ind2="1"><subfield code="a">1988</subfield></datafield><datafield tag="433" ind1="-" ind2="1"><subfield code="a">1 Videokassette, 47 min.</subfield></datafield><datafield tag="434" ind1="-" ind2="1"><subfield code="a">farb., Ton-engl.</subfield></datafield><datafield tag="440" ind1="h" ind2="1"><subfield code="a">VHS</subfield></datafield><datafield tag="511" ind1="-" ind2="1"><subfield code="a">The Hockey Association (Verkauf; 30,- engl. Pfd.)</subfield></datafield><datafield tag="516" ind1="a" ind2="1"><subfield code="a">engl.</subfield></datafield><datafield tag="540" ind1="z" ind2="1"><subfield code="b">30,- engl. Pfd.</subfield></datafield><datafield tag="750" ind1="-" ind2="1"><subfield code="a">David Whitaker, Coaching Director des englischen Hockeyverbandes, zeigt mit Spielszenen der Herren- und Damennationalmannschaften (World Cup 1986; Ladies European Cup 1987; Lada Classics 1987) die hockeytechnischen Grundfertigkeiten Ballführung, Umspielen, Ballabgabe und Ballannahme. Im Anschluß an die Spielszenen werden die Hauptbewegungsmerkmale und didaktisch-methodisch geordnete Trainingsformen mit Kinder- und Jugendmannschaften vorgestellt. Die Erarbeitung der taktischen Fähigkeiten in Kleinfeldspielen (2:1, 3:1, 4:2, 4:4) mit zwei Toren sowie im Mini-Hockey schließen sich an. Die Abschnitte Torschußtraining und Torwarttraining bilden zeitlich und inhaltlich den abschließenden Schwerpunkt.</subfield></datafield><datafield tag="751" ind1="-" ind2="1"><subfield code="a">Hillmann</subfield></datafield><controlfield tag="SYS">011782318</controlfield><datafield tag="088" ind1=" " ind2=" "><subfield code="a">Kn 41</subfield><subfield code="b">M</subfield><subfield code="c">VHOC201</subfield><subfield code="e">ausleihb./Video</subfield></datafield></record></metadata></record></ListRecords></OAI-PMH>